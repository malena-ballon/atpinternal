# Copy this file to .env.local and fill in real values.
# NEVER commit .env.local to version control.

# ── Supabase ───────────────────────────────────────────────────────────────────
# Found in: Supabase dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Service role key — grants full DB access, bypasses RLS.
# NEVER expose this to the browser. Server-side only.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ── Application ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://yourdomain.com

# ── Email (Resend) ─────────────────────────────────────────────────────────────
# Found in: resend.com → API Keys
RESEND_API_KEY=re_your_resend_api_key_here

# ── Cron job authentication ────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
# Used to authenticate requests to /api/cron/reminders
CRON_SECRET=replace-with-32-plus-char-random-secret
